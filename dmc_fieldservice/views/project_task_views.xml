<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_form2_inherit_dmc_fieldservice" model="ir.ui.view">
        <field name="name">project.task.form.inherit.dmc.fieldservice</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="industry_fsm.view_task_form2_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='under_warranty']" position="after">
                <field name="dmc_equipment" invisible="not is_fsm"/>
                <field name="dmc_serial_number" invisible="not is_fsm"/>
                <field name="dmc_equipment_run_hours" invisible="not is_fsm"/>
            </xpath>
        </field>
    </record>

</odoo>
