<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ Wizard Form View ═══════════════════════════════════════════════════ -->

    <record id="dmc_company_setup_wizard_view_form" model="ir.ui.view">
        <field name="name">dmc.company.setup.wizard.form</field>
        <field name="model">dmc.company.setup.wizard</field>
        <field name="arch" type="xml">
            <form string="New Company Setup">

                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="company_info,bank_setup,journal_prefixes,review,done"
                           readonly="1"/>
                </header>

                <sheet>

                    <!-- ── Step 1: Company Information ─────────────────────── -->
                    <group invisible="state != 'company_info'">
                        <group string="Company Details">
                            <field name="company_name"/>
                            <field name="vat"/>
                            <field name="currency_id" options="{'no_create': True}"/>
                            <field name="parent_id" options="{'no_create': True}"/>
                            <field name="tax_source_company_id" options="{'no_create': True}"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="website"/>
                        </group>
                        <group string="Address">
                            <field name="street"/>
                            <field name="street2"/>
                            <field name="city"/>
                            <field name="state_id"
                                   options="{'no_create': True}"
                                   domain="[('country_id', '=', country_id)]"/>
                            <field name="zip"/>
                            <field name="country_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Logo">
                            <field name="logo" widget="image"
                                   options="{'size': [128, 128], 'preview_image': 'logo'}"/>
                        </group>
                    </group>

                    <!-- ── Step 2: Bank Account Setup ──────────────────────── -->
                    <group invisible="state != 'bank_setup'" string="Bank Account">
                        <div class="alert alert-info" role="alert">
                            The account code is auto-generated by incrementing the highest
                            existing Bank/Cash account code. You can override it if needed.
                            All other Chart of Accounts will be mapped to the new company
                            automatically — no new records will be created for them.
                        </div>
                        <group>
                            <field name="bank_account_name"/>
                            <field name="bank_account_code"/>
                            <field name="bank_name" placeholder="e.g. Regions Bank (optional)"/>
                        </group>
                    </group>

                    <!-- ── Step 3: Journal Prefixes ────────────────────────── -->
                    <group invisible="state != 'journal_prefixes'" string="Journal Sequence Prefixes">
                        <div class="alert alert-info" role="alert">
                            These prefixes must be unique across all companies.
                            Append a suffix (e.g. INV3, BNK3) if the defaults conflict.
                        </div>
                        <group>
                            <field name="journal_sales_prefix"/>
                            <field name="journal_purchase_prefix"/>
                            <field name="journal_bank_prefix"/>
                            <field name="journal_misc_prefix"/>
                        </group>
                    </group>

                    <!-- ── Step 4: Review ──────────────────────────────────── -->
                    <group invisible="state != 'review'" string="Review — Everything below will be created">
                        <group string="Company">
                            <field name="company_name" readonly="1"/>
                            <field name="currency_id" readonly="1"/>
                            <field name="parent_id" readonly="1"/>
                            <field name="tax_source_company_id" readonly="1"/>
                        </group>
                        <group string="Bank Account">
                            <field name="bank_account_name" readonly="1"/>
                            <field name="bank_account_code" readonly="1"/>
                        </group>
                        <group string="Journal Prefixes">
                            <field name="journal_sales_prefix" readonly="1"/>
                            <field name="journal_purchase_prefix" readonly="1"/>
                            <field name="journal_bank_prefix" readonly="1"/>
                            <field name="journal_misc_prefix" readonly="1"/>
                        </group>
                        <div class="alert alert-warning" role="alert">
                            Clicking <strong>Create Company</strong> will:
                            <ul>
                                <li>Create the company and its partner record</li>
                                <li>Create a Bank chart account with the auto-generated code</li>
                                <li>Add this company to all existing shared chart accounts (skipped if a parent company is set — accounts are inherited automatically)</li>
                                <li>Copy all taxes, tax groups, and payment providers from the selected source company (if any)</li>
                                <li>Create Sales, Purchase, Bank, and Misc journals</li>
                                <li>Create Cash on Delivery, Demo, and Wire Transfer payment providers</li>
                            </ul>
                            This operation cannot be undone automatically.
                        </div>
                    </group>

                    <!-- ── Step 5: Done ────────────────────────────────────── -->
                    <div invisible="state != 'done'">

                        <!-- Success banner -->
                        <div class="alert alert-success d-flex align-items-center gap-3 mb-4" role="alert">
                            <i class="fa fa-check-circle fa-2x"/>
                            <div>
                                <strong>Company setup completed successfully!</strong><br/>
                                <span><field name="created_company_id" readonly="1" nolabel="1" class="fw-bold"/> is ready to use.</span>
                            </div>
                        </div>

                        <!-- What was created -->
                        <div class="row mt-3">
                            <div class="col-6">
                                <h6 class="text-muted text-uppercase fw-bold mb-2">
                                    <i class="fa fa-building-o me-1"/> Company Details
                                </h6>
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="text-muted" style="width:45%">Company Name</td>
                                        <td><field name="company_name" readonly="1" nolabel="1"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Bank Account Code</td>
                                        <td><field name="bank_account_code" readonly="1" nolabel="1"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Copied Setup From</td>
                                        <td>
                                            <span invisible="not tax_source_company_id">
                                                <field name="tax_source_company_id" readonly="1" nolabel="1"/>
                                            </span>
                                            <span invisible="tax_source_company_id" class="text-muted fst-italic">None selected</span>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <div class="col-6">
                                <h6 class="text-muted text-uppercase fw-bold mb-2">
                                    <i class="fa fa-check me-1"/> What Was Set Up
                                </h6>
                                <ul class="list-unstyled">
                                    <li class="mb-1"><i class="fa fa-check text-success me-2"/>Bank chart account created</li>
                                    <li class="mb-1"><i class="fa fa-check text-success me-2"/>Shared chart accounts mapped</li>
                                    <li class="mb-1">
                                        <span invisible="not tax_source_company_id">
                                            <i class="fa fa-check text-success me-2"/>Tax groups &amp; taxes copied
                                        </span>
                                        <span invisible="tax_source_company_id">
                                            <i class="fa fa-minus text-muted me-2"/>Taxes skipped (no source)
                                        </span>
                                    </li>
                                    <li class="mb-1"><i class="fa fa-check text-success me-2"/>Journals created</li>
                                    <li class="mb-1">
                                        <span invisible="not tax_source_company_id">
                                            <i class="fa fa-check text-success me-2"/>Payment providers copied
                                        </span>
                                        <span invisible="tax_source_company_id">
                                            <i class="fa fa-check text-success me-2"/>Default payment providers created
                                        </span>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Created journals -->
                        <div class="mt-3">
                            <h6 class="text-muted text-uppercase fw-bold mb-2">
                                <i class="fa fa-book me-1"/> Created Journals
                            </h6>
                            <field name="created_journal_ids" readonly="1" nolabel="1" widget="many2many_tags"/>
                        </div>

                    </div>

                </sheet>

                <footer>
                    <!-- Back (steps 2–4) -->
                    <button name="action_back" string="Back" type="object"
                            class="btn-secondary"
                            invisible="state in ('company_info', 'done')"/>

                    <!-- Next (steps 1–3) -->
                    <button name="action_next" string="Next" type="object"
                            class="btn-primary"
                            invisible="state not in ('company_info', 'bank_setup', 'journal_prefixes')"/>

                    <!-- Confirm (step 4) -->
                    <button name="action_create_company" string="Create Company" type="object"
                            class="oe_highlight"
                            invisible="state != 'review'"
                            confirm="This will create the company and all associated accounting records. This cannot be automatically undone. Continue?"/>

                    <!-- Close (step 5) -->
                    <button string="Close" special="cancel"
                            class="btn-primary"
                            invisible="state != 'done'"/>

                    <!-- Cancel (steps 1–4) -->
                    <button string="Cancel" special="cancel"
                            class="btn-secondary"
                            invisible="state == 'done'"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- ══ Action ════════════════════════════════════════════════════════════ -->

    <record id="action_dmc_company_setup_wizard" model="ir.actions.act_window">
        <field name="name">New Company Setup</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">dmc.company.setup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{"dialog_size": "large"}</field>
    </record>

    <!-- ══ Home Page App Tile ════════════════════════════════════════════════ -->
    <menuitem
        id="menu_dmc_company_setup_wizard_root"
        name="Company Setup"
        action="action_dmc_company_setup_wizard"
        web_icon="dmc_company_setup_wizard,static/description/icon.png"
        sequence="100"
        groups="base.group_system"/>

    <!-- ══ Settings → Technical entry ═══════════════════════════════════════ -->
    <menuitem
        id="menu_dmc_company_setup_wizard_technical"
        name="Company Setup Wizard"
        parent="base.menu_administration"
        action="action_dmc_company_setup_wizard"
        groups="base.group_system"
        sequence="100"/>

</odoo>
