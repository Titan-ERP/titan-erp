<odoo>
	<data>
		<record id='dealership_appication_status' model='mail.template'>
			<field name="name">Dealership Request Status</field>
			<field name="model_id" ref="dealership_management.model_dealership_application"/>
			<field name="auto_delete" eval="True"/>
			<field name="subject">Check Your Dealer Application Status</field>
			<field name="email_from">{{ object.env.user.company_id.email }}</field>
			<field name="email_to">{{ object.email }}</field>
			<field name="body_html" type="html">
				<table border="0" cellpadding="0" cellspacing="0" style="padding-top: 16px; background-color: #FFFFFF; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
					<tr>
						<td align="">
							<table border="0" cellpadding="0" cellspacing="0" width="590" style="padding: 16px; background-color: #FFFFFF; color: #454748; border-collapse:separate;">
								<tbody>
									<div>
										<p>Hi <strong>
											<t t-out="object.name"/>
										</strong>
									</p>
									<p>Your Email: <t t-out="object.email"/>
									</p>
									<p>Your Request Id: <t t-out="object.token"/>
									</p>
									<p>
										<t t-if="object.state == 'processed'">
											Thank you for submitting an application, for more information about your application please click on the below link.
										</t>
										<t t-elif="object.state == 'pending'">
											Your dealer application is on pending due to inconsistent information to fill please follow the below link.
										</t>
										<t t-elif="object.state == 'approved'">
											Please check that your application has been approved and is being waited to select your plan.
										</t>
										<t t-elif="object.state == 'decline'">
											Unfortunately, your application has been declined due to inconsistent information.
										</t>
									</p>

									<t t-set="website_url" t-value="object.env['ir.config_parameter'].sudo().get_param('web.base.url')"></t>
									<a t-attf-href="{{website_url}}/dealer/status?db={{ object.env.cr.dbname }}">
										<t t-out="website_url"/>/dealer/status
									</a>
								</div>
							</tbody>
						</table>
					</td>
				</tr>
			</table>
		</field>
	</record>

	<record id='dealership_appication_confirmation_status' model='mail.template'>
		<field name="name">Dealership Application Order Confirmation</field>
		<field name="model_id" ref="dealership_management.model_dealership_application"/>
		<field name="auto_delete" eval="True"/>
		<field name="subject">Dealership Application Order Confirmation</field>
		<field name="email_from">{{ object.env.user.company_id.email }}</field>
		<field name="email_to">{{ object.email }}</field>
		<field name="body_html" type="html">
			<div>
				<h4>Hi <strong>
					<t t-if="object.name">
						<t t-out="object.name"/>
					</t>
				</strong>
			</h4>
			<p>
				<t t-if="object.state == 'approved'">
					Thanks for applying, we have received your order successfully. Now we are processing your application and will update you asap.
				</t>
				<t t-elif="object.state == 'done'">
					Thanks for upgrade your plan, we are processing your dealership plan and will update you asap.
				</t>
			</p>
		</div>
	</field>
</record>

<record id='dealership_appication_done_status' model='mail.template'>
	<field name="name">Dealership Application Confirmation</field>
	<field name="model_id" ref="dealership_management.model_dealership_application"/>
	<field name="auto_delete" eval="True"/>
	<field name="subject">Dealership Application Confirmation</field>
	<field name="email_from">{{ object.env.user.company_id.email }}</field>
	<field name="email_to">{{ object.email }}</field>
	<field name="body_html" type="html">
		<div class="mt-2">
			<h4>Hi <strong>
				<t t-out="object.name"/>
			</strong>
		</h4>
		<span>Congratulations!</span>
		<br />
		Your dealership plan has been activated, please <a t-attf-href="{{ web_url }}/dealer/status?db={{ object.env.cr.dbname }}">check your profile</a>.
	</div>
</field>
</record>

<record id='dealership_appication_submission' model='mail.template'>
	<field name="name">Dealership Application</field>
	<field name="model_id" ref="dealership_management.model_dealership_application"/>
	<field name="auto_delete" eval="True"/>
	<field name="subject">Dealership Application</field>
	<field name="email_from">{{ object.email }}</field>
	<field name="email_to">{{ object.env.user.company_id.email }}</field>
	<field name="body_html" type="html">
		<div>
			<h4>Hi <strong>
				<t t-if="object.env.user.company_id.name">
					<t t-out="object.env.user.company_id.name"/>
				</t>
			</strong>
			</h4>
			<p>
				New application has been arrived. Please take action asap.
			</p>
			<span>Applicant Name:  <t t-out="object.name"/></span>
			<br/>
			<span>Applicant Phone No.:  <t t-out="object.phone"/></span>
			<br/>
			<span>Date: <t t-out="ctx.get('time')"/></span>
			<br />
			<button class="btn-primary"><a t-att-href="ctx.get('view_application')">View Application</a></button>
		</div>
	</field>
</record>

<record id='dealership_appication_expire_status' model='mail.template'>
<field name="name">Dealership Plan Status</field>
<field name="model_id" ref="dealership_management.model_dealership_contract"/>
<field name="auto_delete" eval="True"/>
<field name="subject">Dealership Plan Status</field>
<field name="email_from">{{object.env.user.company_id.email}}</field>
<field name="email_to">{{object.application_id.email}}</field>
<field name="body_html" type="html">
	<p>Hi <strong>
		<t t-if="object.application_id.name">
			<t t-out="object.application_id.name"/>
		</t>
		</strong>
	</p>
	<p>Your Dealership Plan <strong>
	<t t-if="object.plan_id.name">
		<t t-out="object.plan_id.name"/>
	</t>
	</strong> will be going to expire on <strong>
	<t t-if="object.date_to">
		<t t-out="object.date_to"/>
	</t>
	</strong>.
	Please update your payment to re-activate it.</p>
</field>
</record>
</data>
</odoo>