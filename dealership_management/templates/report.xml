<odoo>
  <data>
    <template id="report_contract">
      <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
          <t t-call="web.external_layout">
            <link href="/dealership_management/static/src/scss/report.scss" rel="stylesheet/scss" />
            <div class="page">
              <div t-if="o">
                <t t-set="plan_id" t-value="o.plan_id" />
                <div class="card contract_details bg-200" t-if="plan_id">
                  <div class="card-body text-center">
                    <span t-field="plan_id.image" t-options="{'widget': 'image'}" class="d-flex h-100 justify-content-center align-items-center"  />
                  </div>
                  <div class="card-footer mt-4 p-4">
                    <h5>
                      <b t-esc="plan_id.name" />
                    </h5>
                    <div class="d-flex justify-content-center">
                      <t t-set="user" t-value="env['res.users'].browse(request.env.uid)" />
                      <h5 class="mb-2 text-blod" t-esc="plan_id.get_price(request.session.get('website_sale_current_pl'))" t-options="{'widget': 'monetary', 'display_currency': user.currency_id}" />
                      <small class="d-block mb-2 ms-2">
                        <strong>
                          <span t-esc="plan_id.duration" />
                          <span> / month</span>
                        </strong>
                      </small>
                    </div>
                    <p t-if="o.partner_id" class="mb-2">
                      <strong>Dealer: <span t-esc="o.partner_id.name"/></strong>
                    </p>
                    <p class="mb-2">
                      <strong>Plan Type: <span t-esc="plan_id.type"/></strong>
                    </p>
                  <p class="mb-2">
                    <strong>
                      <span t-esc="plan_id.terms"/>
                    </strong>
                  </p>
                </div>
              </div>
              <div t-else="">
                <strong>Still no Plan is available for this Contract</strong>
              </div>
            </div>
            </div>
          </t>
        </t>
      </t>
    </template>

    <record id="action_report_contract_info" model='ir.actions.report'>
      <field name='name'>Contract Details Pdf</field>
      <field name='model'>dealership.contract</field>
      <field name='report_type'>qweb-pdf</field>
      <field name='report_name'>dealership_management.report_contract</field>
      <field name='report_file'>dealership_management.report_contract</field>
      <field name='print_report_name'>'Contract Details-%s' % (object.id)</field>
      <field name="binding_model_id" ref="model_dealership_contract"/>
      <field name="binding_type">report</field>
    </record>
  </data>
</odoo>
