<odoo>
	<record id="application_history_tree" model="ir.ui.view">
		<field name="name">application.history.list</field>
		<field name="model">application.history</field>
		<field name="type">list</field>
		<field name="arch" type="xml">
			<list>
				<field name="full_fill" />
				<field name="application_id"/>
				<field name="state"/>
				<field name="query"/>
				<field name="ask_attachment"/>
				<field name="app_attachment"/>
			</list>
		</field>
	</record>

	<record id="application_history_form" model="ir.ui.view">
		<field name="name">application.history.form</field>
		<field name="model">application.history</field>
		<field name="type">form</field>
		<field name="arch" type="xml">
			<form>
				<sheet>
					<group>
						<field name="application_id"/>
						<field name="state"/>
					</group>
					<group>
						<field name="query"/>
						<field name="ask_attachment"/>
					</group>
					<group>
						<field name="response"/>
						<field name="app_attachment"/>
					</group>
				</sheet>
			</form>
		</field>
	</record>

	<record id="dealer_history_search_view" model="ir.ui.view">
		<field name="name">application.history.search</field>
		<field name="model">application.history</field>
		<field name="arch" type="xml">
			<search string="History">
				<group>
					<filter string="Dealer Application" name="group_by_application_id" context="{'group_by':'application_id'}"/>
					<filter string="History State" name="group_by_state" context="{'group_by':'state'}"/>
				</group>
			</search>
		</field>
	</record>

	<record id="application_history_action" model='ir.actions.act_window'>
		<field name="name">Application History</field>
		<field name="res_model">application.history</field>
		<field name='view_mode'>list,form</field>
		<field name='context'>{'search_default_group_by_application_id': 1}</field>
	</record>

	<record id="dealership_history_action" model='ir.actions.act_window'>
		<field name="name">Application History</field>
		<field name="res_model">application.history</field>
		<field name='view_mode'>list,form</field>
		<field name='context'>{}</field>
		<field name='domain'>[('application_id.id','=',active_id)]</field>
	</record>
</odoo>
