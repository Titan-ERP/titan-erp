<odoo>
	<data>

		<record id="application_faq_category_tree" model="ir.ui.view">
			<field name="name">application.faq.category.list</field>
			<field name="model">application.faq.category</field>
			<field name="type">list</field>
			<field name="arch" type="xml">
				<list>
					<field name="sequence" widget="handle"/>
					<field name="name" />
				</list>
			</field>
		</record>

		<record id="application_faq_line_tree" model="ir.ui.view">
			<field name="name">application.faq.line.list</field>
			<field name="model">application.faq.line</field>
			<field name="type">list</field>
			<field name="arch" type="xml">
				<list>
					<field name="sequence" widget="handle"/>
					<field name="name" />
					<field name="faq_category_id" />
				</list>
			</field>
		</record>

		<record id="application_faq_category_form" model="ir.ui.view">
			<field name="name">application.faq.category.form</field>
			<field name="model">application.faq.category</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form>
					<sheet>
						<field name="image" class="oe_avatar oe_left" widget="image" />
						<group col="4">
							<field name="name" />
							<field name="sequence"/>
							<field name="description" />
						</group>
					</sheet>
				</form>
			</field>
		</record>

		<record id="application_faq_line_form" model="ir.ui.view">
			<field name="name">application.faq.line.form</field>
			<field name="model">application.faq.line</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form>
					<sheet>
						<group col="4">
							<field name="faq_category_id" />
							<field name="sequence" />
						</group>
						<group>
							<field name="name" />
						</group>
						<group>
							<field name="answer" />
						</group>
						<group>
							<field name="description" />
						</group>
					</sheet>
				</form>
			</field>
		</record>

		<record id="application_faq_search_view" model="ir.ui.view">
			<field name="name">application.faq.search</field>
			<field name="model">application.faq.line</field>
			<field name="arch" type="xml">
				<search string="Application FAQ">
					<group>
						<filter string="Group By Category" name="group_by_faq_category_id" context="{'group_by':'faq_category_id'}"/>
					</group>
				</search>
			</field>
		</record>

		<record id="application_faq_category_action" model='ir.actions.act_window'>
			<field name="name">Category</field>
			<field name="res_model">application.faq.category</field>
			<field name='view_mode'>list,form</field>
		</record>

		<record id="application_faq_line_action" model='ir.actions.act_window'>
			<field name="name">FAQ</field>
			<field name="res_model">application.faq.line</field>
			<field name='view_mode'>list,form</field>
			<field name='context'>{'search_default_group_by_faq_category_id': 1}</field>
		</record>

    </data>
</odoo>
