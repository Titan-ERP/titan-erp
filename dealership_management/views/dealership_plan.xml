<odoo>
	<data>
		<record id="dealership_plan_form" model="ir.ui.view">
			<field name="name">dealership.plan.form</field>
			<field name="model">dealership.plan</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form>
					<sheet>
						<field name="image" widget="image" class="oe_avatar float-end" />
						<group col="4">
							<field name="name"/>
							<field name="price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
							<field name="currency_id" invisible="1"/>
							<field name="type"/>
							<field name="duration"/>
						</group>
						<group string="Terms &amp; Conditions">
						</group>
						<field name="terms" nolabel="1"/>
					</sheet>
				</form>
			</field>
		</record>

		<record id="dealership_plan_tree" model="ir.ui.view">
			<field name="name">dealership.plan.list</field>
			<field name="model">dealership.plan</field>
			<field name="type">list</field>
			<field name="arch" type="xml">
				<list>
					<field name="name"/>
					<field name="currency_id" invisible="1"/>
					<field name="price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
					<field name="type"/>
					<field name="duration"/>
				</list>
			</field>
		</record>

		<record id="dealership_plan_kanban" model="ir.ui.view">
			<field name="name">dealership.plan.kanban</field>
			<field name="model">dealership.plan</field>
			<field name="type">kanban</field>
			<field name="arch" type="xml">
				<kanban>
					<field name="id"/>
					<field name="currency_id"/>
					<templates>
						<t t-name="card" class="flex-row">
							<aside>
								<field
									name="image"
									widget="image"
									alt="Plan"
									options="{'img_class': 'w-100 object-fit-contain'}" />
							</aside>
							<main class="ps-2">
								<div class="mb-1">
									<div class="d-flex mb-2 h3">
										<field name="name"/>
									</div>
									<span>Plan Type: <field name="type" /></span>
									<br/>
									<span>Duration: <field name="duration" /></span>
									<br/>
									<span>Price: <field name="price" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" /></span>
								</div>
							</main>
						</t>
					</templates>
				</kanban>
			</field>
		</record>

		<record id="dealership_plan_action" model='ir.actions.act_window'>
			<field name="name">Plan</field>
			<field name="res_model">dealership.plan</field>
			<field name='view_mode'>kanban,list,form</field>
			<field name='context'>{}</field>
			<field name='domain'>[]</field>
		</record>
	</data>
</odoo>
