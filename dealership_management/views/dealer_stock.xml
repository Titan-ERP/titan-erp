<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>
		<record id="dealership_stock_tree" model="ir.ui.view">
			<field name="name">dealership.stock.list</field>
			<field name="model">dealer.stock.line</field>
			<field name="type">list</field>
			<field name="arch" type="xml">
				<list editable="top">
					<field name="product_id"/>
					<field name="qty"/>
				</list>
			</field>
		</record>

		<record id="dealer_stock_action" model='ir.actions.act_window'>
			<field name="name">Dealer Stock</field>
			<field name="res_model">dealer.stock.line</field>
			<field name='view_mode'>list</field>
			<field name='context'>{}</field>
			<field name='domain'>[]</field>
		</record>
	</data>
</odoo>
