<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_dmc_sales" model="ir.ui.view">
        <field name="name">sale.order.form.dmc.sales</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Include Shop Supply's checkbox in header, below Payment Terms -->
            <field name="payment_term_id" position="after">
                <field name="include_shop_supply"/>
            </field>

            <!--
                Mirror the exact DOM structure of the tax_totals widget:
                <table class="float-end"> with o_td_label / o_list_monetary cells.
                This keeps the label and amount on the same row, right-aligned,
                matching the Untaxed Amount and Total rows above.
            -->
            <group name="sale_total" position="inside">
                <div invisible="not include_shop_supply">
                    <table class="float-end">
                        <tbody>
                            <tr>
                                <td class="o_td_label">
                                    <label class="o_form_label o_tax_total_label">Shop Supply's</label>
                                </td>
                                <td class="o_list_monetary">
                                    <field name="shop_supply_amount" nolabel="1" widget="monetary" readonly="1"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </group>

        </field>
    </record>
</odoo>
