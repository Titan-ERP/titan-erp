<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_dmc_sales" model="ir.ui.view">
        <field name="name">sale.order.form.dmc.sales</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Include Shop Supply's checkbox in header, below Payment Terms -->
            <field name="payment_term_id" position="after">
                <field name="include_shop_supply"/>
            </field>

            <!-- Shop Supply's in the totals column (oe_subtotal_footer), below Total -->
            <group name="sale_total" position="inside">
                <field name="shop_supply_amount"
                       invisible="not include_shop_supply"
                       readonly="1"
                       widget="monetary"/>
            </group>

        </field>
    </record>
</odoo>
