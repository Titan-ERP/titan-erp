<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_dmc_sales" model="ir.ui.view">
        <field name="name">account.move.form.dmc.sales</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Include Shop Supply's checkbox next to Payment Terms in the invoice header -->
            <field name="invoice_payment_term_id" position="after">
                <field name="include_shop_supply"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
            </field>

        </field>
    </record>
</odoo>
