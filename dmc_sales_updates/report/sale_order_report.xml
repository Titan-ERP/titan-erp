<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Render a description sub-row immediately after the Shop Supply's amount
        row in the sale order PDF.  The shop_supply_description key is set only
        on the injected tax_group entry, so the extra <tr> appears only there.
    -->
    <template id="shop_supply_desc_row_sale" inherit_id="sale.document_tax_totals">
        <xpath expr="//tr[hasclass('o_taxes')]" position="after">
            <tr t-if="tax_group.get('shop_supply_description')">
                <td colspan="2" class="text-muted fst-italic small ps-2">
                    <span t-out="tax_group['shop_supply_description']"/>
                </td>
            </tr>
        </xpath>
    </template>

    <!--
        Same description sub-row for the invoice PDF, which uses
        account.document_tax_totals instead of the sale-specific copy.
    -->
    <template id="shop_supply_desc_row_invoice" inherit_id="account.document_tax_totals">
        <xpath expr="//tr[hasclass('o_taxes')]" position="after">
            <tr t-if="tax_group.get('shop_supply_description')">
                <td colspan="2" class="text-muted fst-italic small ps-2">
                    <span t-out="tax_group['shop_supply_description']"/>
                </td>
            </tr>
        </xpath>
    </template>
</odoo>
