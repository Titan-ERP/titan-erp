<odoo>
    <data noupdate="1">
        <!-- Demo Partners -->
        <record id="demo_rental_customer" model="res.partner">
            <field name="name">Demo Rental Customer</field>
            <field name="email">demo.rental@example.com</field>
            <field name="phone">+61 2 9876 5432</field>
            <field name="street">123 Construction Way</field>
            <field name="city">Sydney</field>
            <field name="state_id" ref="base.state_au_2"/>
            <field name="zip">2000</field>
            <field name="country_id" ref="base.au"/>
        </record>

        <!-- Product Categories with Templates -->
        <record id="rental_equipment_category" model="product.category">
            <field name="name">Rental Equipment</field>
            <field name="parent_id" ref="product.product_category_1"/>
            <field name="pickup_template_id" ref="basic_condition_pickup_template"/>
            <field name="return_template_id" ref="basic_condition_return_template"/>
        </record>

        <record id="heavy_machinery_category" model="product.category">
            <field name="name">Heavy Machinery</field>
            <field name="parent_id" ref="rental_equipment_category"/>
            <field name="pickup_template_id" ref="heavy_equipment_pickup_template"/>
            <field name="return_template_id" ref="heavy_equipment_return_template"/>
        </record>

        <!-- Rental Products -->
        <record id="product_rental_excavator" model="product.product">
            <field name="name">5T Excavator</field>
            <field name="type">consu</field>
            <field name="is_storable" eval="True"/>
            <field name="categ_id" ref="heavy_machinery_category"/>
            <field name="rent_ok" eval="True"/>
            <field name="list_price">450.00</field>
            <field name="standard_price">250.00</field>
            <field name="uom_id" ref="uom.product_uom_unit"/>
            <field name="uom_po_id" ref="uom.product_uom_unit"/>
            <field name="description">5 Tonne Excavator for rental</field>
            <field name="tracking">serial</field>
            <field name="default_code">RENT-EXC-5T</field>
        </record>

        <record id="product_rental_bulldozer" model="product.product">
            <field name="name">Compact Bulldozer</field>
            <field name="type">consu</field>
            <field name="is_storable" eval="True"/>
            <field name="categ_id" ref="heavy_machinery_category"/>
            <field name="rent_ok" eval="True"/>
            <field name="list_price">600.00</field>
            <field name="standard_price">350.00</field>
            <field name="uom_id" ref="uom.product_uom_unit"/>
            <field name="uom_po_id" ref="uom.product_uom_unit"/>
            <field name="description">Compact Bulldozer for rental</field>
            <field name="tracking">serial</field>
            <field name="default_code">RENT-BLD-CMP</field>
        </record>

        <!-- Product Serial Numbers -->
        <record id="lot_excavator_01" model="stock.lot">
            <field name="name">EXC-2024-001</field>
            <field name="product_id" ref="product_rental_excavator"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="lot_bulldozer_01" model="stock.lot">
            <field name="name">BLD-2024-001</field>
            <field name="product_id" ref="product_rental_bulldozer"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Initial Stock -->
        <record id="stock_excavator" model="stock.quant">
            <field name="product_id" ref="product_rental_excavator"/>
            <field name="lot_id" ref="lot_excavator_01"/>
            <field name="location_id" ref="stock.stock_location_stock"/>
            <field name="quantity">1</field>
        </record>

        <record id="stock_bulldozer" model="stock.quant">
            <field name="product_id" ref="product_rental_bulldozer"/>
            <field name="lot_id" ref="lot_bulldozer_01"/>
            <field name="location_id" ref="stock.stock_location_stock"/>
            <field name="quantity">1</field>
        </record>

        <!-- Rental Orders -->
        <record id="demo_rental_order_1" model="sale.order">
            <field name="partner_id" ref="demo_rental_customer"/>
            <field name="partner_invoice_id" ref="demo_rental_customer"/>
            <field name="partner_shipping_id" ref="demo_rental_customer"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="team_id" ref="sales_team.team_sales_department"/>
            <field name="date_order" eval="DateTime.today()"/>
            <field name="rental_start_date" eval="DateTime.today() + relativedelta(days=1)"/>
            <field name="rental_return_date" eval="DateTime.today() + relativedelta(days=6)"/>
        </record>

        <record id="demo_rental_order_line_1" model="sale.order.line">
            <field name="order_id" ref="demo_rental_order_1"/>
            <field name="product_id" ref="product_rental_excavator"/>
            <field name="product_uom_qty">1</field>
            <field name="product_uom" ref="uom.product_uom_unit"/>
            <field name="name">5T Excavator Rental</field>
            <field name="price_unit">450.00</field>
        </record>

        <record id="demo_rental_order_line_1" model="sale.order.line">
            <field name="is_rental" eval="True"/>
        </record>

        <!-- Confirm rental order -->
        <function model="sale.order" name="action_confirm" eval="[[ref('demo_rental_order_1')]]" context="{'action_no_send_mail': True}"/>

        <!-- Complete the rental order -->
        <function model="sale.order" name="action_confirm">
            <value eval="[ref('demo_rental_order_1')]"/>
        </function>

        <!-- Demo Inspections -->
        <record id="demo_inspection_pickup" model="rental.inspection">
            <field name="rental_order_id" ref="demo_rental_order_1"/>
            <field name="product_id" ref="product_rental_excavator"/>
            <field name="type">pickup</field>
            <field name="equipment_hours">1250.5</field>
            <field name="state">done</field>
            <field name="damage_found" eval="False"/>
            <field name="customer_name">John Smith</field>
            <field name="date">2025-01-10 07:00:00</field>
        </record>

        <!-- Create checklist items for the pickup inspection -->
        <function model="rental.inspection" name="action_start_inspection">
            <value eval="[ref('demo_inspection_pickup')]"/>
        </function>

        <function model="rental.inspection" name="action_complete_inspection">
            <value eval="[ref('demo_inspection_pickup')]"/>
        </function>

        <!-- Demo Return Inspection (5 days later) -->
        <record id="demo_inspection_return" model="rental.inspection">
            <field name="rental_order_id" ref="demo_rental_order_1"/>
            <field name="product_id" ref="product_rental_excavator"/>
            <field name="type">return</field>
            <field name="equipment_hours">1275.5</field>
            <field name="state">done</field>
            <field name="damage_found" eval="True"/>
            <field name="damage_description">Minor scraping on the right side of the bucket.</field>
            <field name="customer_name">John Smith</field>
            <field name="date">2025-01-15 17:00:00</field>
        </record>

        <!-- Create checklist items for the return inspection -->
        <function model="rental.inspection" name="action_start_inspection">
            <value eval="[ref('demo_inspection_return')]"/>
        </function>

        <function model="rental.inspection" name="action_complete_inspection">
            <value eval="[ref('demo_inspection_return')]"/>
        </function>
    </data>
</odoo>