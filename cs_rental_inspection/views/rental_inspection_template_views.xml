<odoo>
    <!-- Template Form View -->
    <record id="rental_inspection_template_form" model="ir.ui.view">
        <field name="name">rental.inspection.template.form</field>
        <field name="model">rental.inspection.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Heavy Equipment Pickup"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="type"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                        </group>
                    </group>
                    <notebook>
                        <page string="Checklist Items" name="checklist_items">
                            <div class="alert alert-info" role="alert">
                                Click 'Add a line' to create inspection checklist items. Each item can be configured with specific requirements.
                            </div>
                            <field name="item_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="type"/>
                                    <field name="require_photo"/>
                                    <field name="require_note"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group string="Basic Information">
                                                <field name="name" placeholder="e.g. Check Engine Oil Level"/>
                                                <field name="type"/>
                                            </group>
                                            <group string="Requirements">
                                                <field name="require_photo" widget="boolean_toggle"/>
                                                <field name="require_note" widget="boolean_toggle"/>
                                            </group>
                                        </group>
                                        <group string="Instructions">
                                            <field name="description" placeholder="Enter detailed instructions or acceptance criteria for this check..."/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Add any general instructions or notes for inspectors..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Template List View -->
    <record id="rental_inspection_template_list" model="ir.ui.view">
        <field name="name">rental.inspection.template.list</field>
        <field name="model">rental.inspection.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="type"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Template Search View -->
    <record id="rental_inspection_template_search" model="ir.ui.view">
        <field name="name">rental.inspection.template.search</field>
        <field name="model">rental.inspection.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Pickup Templates" name="pickup" domain="[('type', '=', 'pickup')]"/>
                <filter string="Return Templates" name="return" domain="[('type', '=', 'return')]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    <filter string="Type" name="groupby_type" context="{'group_by': 'type'}"/>
            </search>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_rental_inspection_template" model="ir.actions.act_window">
        <field name="name">Inspection Templates</field>
        <field name="res_model">rental.inspection.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="rental_inspection_template_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first inspection template
            </p>
            <p>
                Define templates for different inspection types that can be assigned to equipment categories.
            </p>
        </field>
    </record>
</odoo>
