<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="dmc_backup_folder_wizard_form_view" model="ir.ui.view">
        <field name="name">dmc.backup.folder.wizard.form</field>
        <field name="model">dmc.backup.folder.wizard</field>
        <field name="arch" type="xml">
            <form string="Browse OneDrive Folders">
                <sheet>
                    <group>
                        <field name="parent_path" string="Current Path" readonly="1"/>
                    </group>
                    <field name="folder_ids" nolabel="1">
                        <list string="Folders" create="false" delete="false" edit="false">
                            <field name="name" string="Folder"/>
                            <field name="path" string="Path"/>
                            <button name="action_open" type="object"
                                    string="Open" icon="fa-folder-open"/>
                            <button name="action_select" type="object"
                                    string="Select" icon="fa-check"
                                    class="btn-primary"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
