<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        titan_theme/views/assets.xml
        Registers the Google Fonts preconnect link in the website <head>.
        SCSS assets are registered via __manifest__.py 'assets' key — not here.
        This file handles any additional <head> assets (fonts, preconnect, etc.)
    -->

    <!-- Inject Google Fonts preconnect + stylesheet into every website page -->
    <template id="assets_frontend_google_fonts"
              name="Titan Theme: Google Fonts"
              inherit_id="website.layout">
        <xpath expr="//head" position="inside">
            <!-- Preconnect for faster font load -->
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
            <!-- Inter + Inter Tight — weights used across the theme -->
            <link
                href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=Inter+Tight:wght@400;500;600;700;800&amp;display=swap"
                rel="stylesheet"/>
        </xpath>
    </template>

</odoo>
